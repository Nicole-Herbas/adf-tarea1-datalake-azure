{
	"name": "df_venta_online_bronze_silver",
	"properties": {
		"folder": {
			"name": "bronze"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ventas_online_csv",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ventas_scz_limpio_csv",
						"type": "DatasetReference"
					},
					"name": "sink1",
					"description": "Exportar datos a ventas_online_limpio_csv"
				}
			],
			"transformations": [
				{
					"name": "select1"
				},
				{
					"name": "trim"
				},
				{
					"name": "derivedColumn1"
				},
				{
					"name": "filter1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          order_id as string,",
				"          timestamp as string,",
				"          product as string,",
				"          qty as string,",
				"          unit_price as string,",
				"          {customer/name} as string,",
				"          {customer/email} as string,",
				"          {customer/city} as string,",
				"          payment_method as string,",
				"          status as string,",
				"          shipping_cost as string,",
				"          channel as string,",
				"          customer as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source1 select(mapColumn(",
				"          id_venta = order_id,",
				"          fecha = timestamp,",
				"          producto = product,",
				"          cantidad = qty,",
				"          precio_unitario = unit_price,",
				"          cliente_nombre = {customer/name},",
				"          cliente_email = {customer/email},",
				"          sucursal = {customer/city},",
				"          metodo_pago = payment_method,",
				"          vendedor = customer",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"select1 derive(id_venta = trim(id_venta),",
				"          fecha = trim(fecha),",
				"          producto = trim(producto),",
				"          cantidad = trim(cantidad),",
				"          precio_unitario = trim(precio_unitario),",
				"          cliente_nombre = trim(cliente_nombre),",
				"          cliente_email = trim(cliente_email),",
				"          sucursal = trim(sucursal),",
				"          metodo_pago = trim(metodo_pago),",
				"          vendedor = trim(vendedor),",
				"          canal = 'Online') ~> trim",
				"trim derive(fecha = coalesce(\r",
				"toDate(fecha, 'yyyy-MM-dd'),\r",
				"toDate(fecha, 'dd-MM-yyyy'),\r",
				"toDate(fecha, 'MM-dd-yyyy'),\r",
				"toDate(fecha, 'dd/MM/yyyy'),\r",
				"toDate(fecha, 'yyyy/MM/dd'),\r",
				"toDate(fecha, 'dd/MM/yyyy'),\r",
				"toDate(fecha, 'dd/MMM/yyyy'),\r",
				"toDate(fecha, 'dd-MMM-yyyy')),",
				"          cantidad = toInteger(cantidad),",
				"          precio_unitario = toFloat(regexReplace(toString(precio_unitario), '[^0-9.]', '')),",
				"          producto = initCap(trim(regexReplace(producto, '\\\\s+',' ')))) ~> derivedColumn1",
				"derivedColumn1 filter(cantidad>0 && !isNull(precio_unitario) && !isNull(fecha)) ~> filter1",
				"filter1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     partitionFileNames:['ventas_online_limpio.csv'],",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     partitionBy('hash', 1)) ~> sink1"
			]
		}
	}
}