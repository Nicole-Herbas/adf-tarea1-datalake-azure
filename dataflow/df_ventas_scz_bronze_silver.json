{
	"name": "df_ventas_scz_bronze_silver",
	"properties": {
		"folder": {
			"name": "bronze"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ventas_scz_csv",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ventas_scz_limpio_csv",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "trim"
				},
				{
					"name": "may"
				},
				{
					"name": "scz"
				},
				{
					"name": "float"
				},
				{
					"name": "fecha"
				},
				{
					"name": "nulos"
				},
				{
					"name": "select1"
				},
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          id_venta as string,",
				"          fecha as string,",
				"          producto as string,",
				"          cantidad as string,",
				"          precio_unitario as string,",
				"          sucursal as string,",
				"          vendedor as string,",
				"          cliente_nombre as string,",
				"          cliente_email as string,",
				"          metodo_pago as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source1 derive(vendedor = trim(vendedor),",
				"          cliente_nombre = trim(cliente_nombre),",
				"          id_venta = trim(id_venta),",
				"          fecha = trim(fecha),",
				"          producto = trim(producto),",
				"          cantidad = trim(cantidad),",
				"          precio_unitario = trim(precio_unitario),",
				"          sucursal = trim(sucursal),",
				"          cliente_email = trim(cliente_email),",
				"          metodo_pago = trim(metodo_pago)) ~> trim",
				"trim derive(producto = initCap(regexReplace(producto,'\\\\s+',' '))) ~> may",
				"may derive(sucursal = iif(in(['SCZ','Santa Cruz','Sta Cruz','santa cruz','SANTA CRUZ','Sta. Cruz','SC'], sucursal),'Santa Cruz',sucursal)) ~> scz",
				"scz derive(precio_unitario = toFloat(regexReplace(toString(precio_unitario),'[^0-9.]',''))\r",
				",",
				"          cantidad = toInteger(cantidad)) ~> float",
				"float derive(fecha = coalesce(\r",
				"toDate(fecha, 'yyyy-MM-dd'),\r",
				"toDate(fecha, 'dd-MM-yyyy'),\r",
				"toDate(fecha, 'MM-dd-yyyy'),\r",
				"toDate(fecha, 'dd/MM/yyyy'),\r",
				"toDate(fecha, 'yyyy/MM/dd'),\r",
				"toDate(fecha, 'dd/MM/yyyy'),\r",
				"toDate(fecha, 'dd/MMM/yyyy'),\r",
				"toDate(fecha, 'dd-MMM-yyyy'))) ~> fecha",
				"fecha filter(cantidad>0 && !isNull(precio_unitario) && !isNull(fecha)) ~> nulos",
				"nulos select(mapColumn(",
				"          id_venta,",
				"          fecha,",
				"          producto,",
				"          cantidad,",
				"          precio_unitario,",
				"          sucursal,",
				"          vendedor,",
				"          cliente_nombre,",
				"          cliente_email,",
				"          metodo_pago",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"select1 derive(canal = 'Sucursal') ~> derivedColumn1",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     partitionFileNames:['ventas_scz_limpio.csv'],",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     partitionBy('hash', 1)) ~> sink1"
			]
		}
	}
}